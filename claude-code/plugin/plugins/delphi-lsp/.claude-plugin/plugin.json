{
  "name": "delphi-lsp",
  "version": "1.1.0",
  "description": "Delphi/Pascal language server using delphi-lookup index",
  "lspServers": {
    "delphi": {
      "command": "__DELPHI_LSP_SERVER_PATH__",
      "args": ["--database", "__DELPHI_SYMBOLS_DB_PATH__"],
      "extensionToLanguage": {
        ".pas": "pascal",
        ".dpr": "pascal",
        ".dpk": "pascal",
        ".inc": "pascal"
      },
      "startupTimeout": 10000
    }
  }
}
